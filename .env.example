# =============================================================================
# 김과외 어드민 도구 - 환경변수 템플릿
# =============================================================================
# 이 파일은 git에 포함됩니다. 실제 값은 절대 여기 적지 마세요.
# 실제 값은 .env.local (로컬) 또는 Vercel Dashboard (운영) 에 등록합니다.
#
# 가장 쉬운 방법: `npm run setup-secrets` 한 번 실행하면 자동 생성됩니다.
# =============================================================================

# --- 인증 (회전 대상) ---
# 평문 비밀번호 X. bcrypt 해시만 저장.
# 새 비밀번호 만들기: node scripts/hash-password.mjs '새비밀번호'
ADMIN_PW_HASH=
# 비밀번호 바꿀 때마다 +1. 기존 세션 즉시 무효화됨.
PW_VERSION=1

# --- 시크릿 (1회 생성, 고정) ---
# 둘 다 32바이트 이상 랜덤. 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SIGNING_SECRET=
BACKEND_SHARED_SECRET=

# --- 백엔드 ---
AZURE_API_BASE=https://dev-admin-api-cycndteybqbvbzc4.koreacentral-01.azurewebsites.net

# --- 쿠키/CORS ---
SESSION_COOKIE_NAME=ka_admin_sid
# 배포 후 실제 도메인으로 교체. 로컬에서는 http://localhost:5173 사용.
ALLOWED_ORIGIN=http://localhost:5173
